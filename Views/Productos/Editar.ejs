<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Editar Producto</title>

<link rel="stylesheet" href="/css/estilo.css">

</head>
<body>

<%- include('../Partials/Menu') %>

<div class="contenedor">

<h1>Editar Producto</h1>

<form
action="/productos/editar/<%= Producto.IdProducto %>"
method="POST">

<p>Nombre Producto</p>

<input
type="text"
name="NombreProducto"
value="<%= Producto.NombreProducto %>"
required>

<p>Presentación</p>

<input
type="text"
name="CantidadPorUnidad"
value="<%= Producto.CantidadPorUnidad %>"
required>

<p>Precio</p>

<input
type="number"
step="0.01"
name="PrecioUnidad"
value="<%= Producto.PrecioUnidad %>"
required>

<p>Stock</p>

<input
type="number"
name="UnidadesEnExistencia"
value="<%= Producto.UnidadesEnExistencia %>"
required>

<p>Descuento (%)</p>

<input
type="number"
step="0.01"
name="Descuento"
value="<%= Producto.Descuento %>">

<p>Categoría</p>

<select name="IdCategoria">

<% Categorias.forEach(function(cat){ %>

<option
value="<%= cat.IdCategoria %>"
<%= cat.IdCategoria == Producto.IdCategoria ? 'selected' : '' %>>
<%= cat.NombreCategoria %>
</option>

<% }) %>

</select>

<br><br>

<button type="submit">
Actualizar Producto
</button>

</form>

</div>

</body>
</html>