<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Nuevo Pedido</title>
    <link rel="stylesheet" href="/css/estilo.css">
</head>

<body>

<%- include('../Partials/Menu') %>

<div class="contenedor">

    <h1>Nuevo Pedido</h1>

    <form action="/pedidos/nuevo" method="POST" class="formulario-card">

        <label>Cliente</label>
        <select name="IdCliente" required>
            <% Clientes.forEach(c=>{ %>
                <option value="<%= c.IdCliente %>">
                    <%= c.NombreEmpresa %>
                </option>
            <% }) %>
        </select>

        <label>Empleado</label>
        <select name="IdEmpleado" required>
            <% Empleados.forEach(e=>{ %>
                <option value="<%= e.IdEmpleado %>">
                    <%= e.Nombre %>
                </option>
            <% }) %>
        </select>

        <label>Fecha Pedido</label>
        <input type="date" name="FechaPedido" required>

        <hr>

        <h2>Productos del Pedido</h2>

        <div id="productosPedido">

            <div class="fila-producto">

                <div>
                    <label>Producto</label>
                    <select name="IdProducto[]" required>
                        <% Productos.forEach(p=>{ %>
                            <option value="<%= p.IdProducto %>">
                                <%= p.NombreProducto %> -
                                S/. <%= p.PrecioUnidad %> -
                                Stock: <%= p.UnidadesEnExistencia %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div>
                    <label>Cantidad</label>
                    <input
                        type="number"
                        name="Cantidad[]"
                        min="1"
                        required>
                </div>

                <div class="contenedor-quitar">
                    <button
                        type="button"
                        class="btn-quitar"
                        onclick="quitarProducto(this)">
                        Quitar
                    </button>
                </div>

            </div>

        </div>

        <button
            type="button"
            class="btn-agregar"
            onclick="agregarProducto()">
            ➕ Agregar Producto
        </button>

        <br><br>

        <button type="submit" class="popup">
            Generar Nuevo Pedido
        </button>

    </form>

</div>

<script>

function agregarProducto() {

    const contenedor = document.getElementById('productosPedido');

    const filaOriginal = document.querySelector('.fila-producto');

    const nuevaFila = filaOriginal.cloneNode(true);

    nuevaFila.querySelector('input').value = '';

    contenedor.appendChild(nuevaFila);
}

function quitarProducto(boton) {

    const filas = document.querySelectorAll('.fila-producto');

    if (filas.length > 1) {
        boton.closest('.fila-producto').remove();
    } else {
        alert('Debe existir al menos un producto en el pedido.');
    }
}

</script>

</body>
</html>